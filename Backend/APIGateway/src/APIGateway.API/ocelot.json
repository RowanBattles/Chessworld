{
  "Routes": [
    {
      "DownstreamPathTemplate": "/gamehub",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "gameservice", "Port": 8080 }
      ],
      "UpstreamPathTemplate": "/gamehub",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
      "EnableWebSockets": true,
      "UseWebSockets": true,
      "AdditionalRequestHeadersToForward": [ "Upgrade", "Connection", "Sec-WebSocket-Version", "Sec-WebSocket-Key", "Sec-WebSocket-Extensions" ]
    },
    {
      "DownstreamPathTemplate": "/gamehub/negotiate",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "gameservice", "Port": 8080 }
      ],
      "UpstreamPathTemplate": "/gamehub/negotiate",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    }
  ]
}