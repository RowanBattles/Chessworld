{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/matchmaking/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "matchmakingservice",
          "Port": 8082
        }
      ],
      "UpstreamPathTemplate": "/api/matchmaking/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "DownstreamPathTemplate": "/gamehub/{everything}",
      "DownstreamScheme": "ws",
      "DownstreamHostAndPorts": [
        {
          "Host": "gameservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gamehub/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "UseWebSockets": true
    },
    {
      "DownstreamPathTemplate": "/matchmaking/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "matchmakingservice",
          "Port": 8082
        }
      ],
      "UpstreamPathTemplate": "/matchmaking/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}
